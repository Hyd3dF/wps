# Yalnizca lokal Docker gelistirme altyapisi icindir.
DEV_POSTGRES_PASSWORD=replace-with-a-long-random-password
DEV_MINIO_ACCESS_KEY=replace-with-a-random-access-key
DEV_MINIO_SECRET_KEY=replace-with-a-long-random-secret

# backend/.env icin karsiliklari:
# DATABASE_URL=postgresql://konu:<DEV_POSTGRES_PASSWORD>@localhost:5432/konu
# DATABASE_SSL_MODE=disable
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY=<DEV_MINIO_ACCESS_KEY>
# MINIO_SECRET_KEY=<DEV_MINIO_SECRET_KEY>

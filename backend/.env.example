# ============ Konu Backend — Ortam Degiskenleri ============
# Bu dosya sablondur. Kopyasini `.env` olarak olusturun veya sistem
# ortam degiskenleri olarak tanimlayin. Gizli anahtarlar (JWT, API key)
# asla repoya islenmez — `npm run setup` bunlari `.env`'e otomatik yazar.

# --- Uygulama ---
NODE_ENV=development
PORT=8080
# Web uygulamasinin origin'i (CORS). Virgulle birden fazla: https://app.konu.dev,https://konu.dev
WEB_APP_ORIGIN=http://localhost:3000

# --- PostgreSQL ---
DATABASE_URL=postgresql://konu:konu_pass@localhost:5432/konu
DATABASE_SSL_MODE=disable
# verify-full icin PEM CA sertifikasi (tek satir, \n kacisli)
DATABASE_SSL_CA=
TRUST_PROXY_HOPS=0

# --- JWT (RS256) ---
# Bos birakirsaniz `npm run setup` 4096-bit RSA anahtar cifti uretir ve .env'e yazar.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# Coolify gibi ortamlarda PEM yerine Base64 kullanmak daha guvenlidir.
# B64 degerleri tanimliysa yukaridaki ham PEM degerlerinden once kullanilir.
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=
JWT_ISSUER=konu-backend
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Servis API anahtari ---
# Bos birakirsaniz `npm run setup` uretir ve .env'e yazar.
SERVICE_API_KEY=

# --- MinIO (S3-uyumlu) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=konu-photos
# Public URL oneki (CDN veya backend proxy), orn. https://api.example.com/uploads
# Bos ise relative /uploads yolu kullanilir.
MINIO_PUBLIC_BASE_URL=

# --- Yukleme / Foto isleme ---
UPLOAD_MAX_BYTES=15728640
PHOTO_MAX_DIMENSION=1700
PHOTO_QUALITY=85
PHOTO_MAX_PIXELS=40000000
ALLOWED_PHOTO_MIMES=image/jpeg,image/png,image/webp
AVATAR_MAX_DIMENSION=256

# --- HTTPS (opsiyonel, ters proxy onerilir) ---
HTTPS_CERT=
HTTPS_KEY=

# --- Rate limit (opsiyonel) ---
RATE_LIMIT_GENERAL_MAX=600
RATE_LIMIT_GENERAL_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=20
RATE_LIMIT_LOGIN_WINDOW_MS=60000
RATE_LIMIT_REGISTER_MAX=10
RATE_LIMIT_REGISTER_WINDOW_MS=3600000
RATE_LIMIT_UPLOAD_MAX=40
RATE_LIMIT_UPLOAD_WINDOW_MS=3600000
